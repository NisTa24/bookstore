<h1>Register Stock</h1>

<% if flash[:alert] %>
  <div style="color: red;">
    <p><%= flash[:alert] %></p>
  </div>
<% end %>

<%= form_with scope: :stock, url: inventory_stock_items_path, method: :post do |f| %>
  <div>
    <%= f.label :book_id, "Book" %>
    <%= f.collection_select :book_id, @books, :book_id, :title, include_blank: "Select a book" %>
  </div>
  <div>
    <%= f.label :quantity %>
    <%= f.number_field :quantity, required: true, min: 1 %>
  </div>
  <div>
    <%= f.submit "Register Stock" %>
  </div>
<% end %>

<%= link_to "Back to Books", catalog_books_path %>
