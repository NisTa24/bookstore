<h1>Books</h1>

<table>
  <thead>
    <tr>
      <th>Title</th>
      <th>ISBN</th>
      <th>Author</th>
      <th>Category</th>
      <th>Price</th>
      <th>Stock</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    <% @books.each do |book| %>
      <tr>
        <td><%= link_to book.title, catalog_book_path(book.book_id) %></td>
        <td><%= book.isbn %></td>
        <td><%= book.author_name %></td>
        <td><%= book.category_name %></td>
        <td><%= book.price_cents.present? ? number_to_currency(book.price_cents) : '' %></td>
        <td><%= book.stock_available %></td>
        <td><%= book.status %></td>
      </tr>
    <% end %>
  </tbody>
</table>
